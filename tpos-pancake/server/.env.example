# Server
PORT=3000

# Facebook App (lấy từ https://developers.facebook.com/apps/)
APP_SECRET=your_facebook_app_secret

# Webhook Verify Token (tự đặt, phải trùng với cấu hình trên App Dashboard)
VERIFY_TOKEN=n2store_webhook_token

# Facebook Page (dùng để subscribe page và gửi tin nhắn)
PAGE_ACCESS_TOKEN=your_page_access_token
PAGE_ID=your_page_id
