{
  "manifest_version": 3,
  "name": "N2 FB Cookie Helper",
  "version": "1.2.0",
  "description": "1-click đăng nhập N2 Ads Manager bằng tài khoản Facebook",
  "permissions": ["cookies", "activeTab", "scripting", "tabs", "webRequest"],
  "host_permissions": [
    "https://*.facebook.com/*",
    "https://*.fbcdn.net/*",
    "https://business.facebook.com/*",
    "https://adsmanager.facebook.com/*",
    "https://graph.facebook.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://adsmanager.facebook.com/*",
        "https://business.facebook.com/*",
        "https://www.facebook.com/adsmanager/*"
      ],
      "js": ["intercept.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": [
        "https://adsmanager.facebook.com/*",
        "https://business.facebook.com/*",
        "https://www.facebook.com/adsmanager/*"
      ],
      "js": ["relay.js"],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
