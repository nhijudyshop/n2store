{
  "manifest_version": 3,
  "name": "N2 FB Cookie Helper",
  "version": "1.3.0",
  "description": "1-click đăng nhập N2 Ads Manager bằng tài khoản Facebook",
  "permissions": ["cookies", "tabs"],
  "host_permissions": [
    "https://*.facebook.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
