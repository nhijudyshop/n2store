{
    "manifest_version": 3,
    "name": "N2Store Messenger",
    "short_name": "N2Store",
    "version": "1.0.14",
    "description": "N2Store unified messaging & management extension",
    "icons": {
        "16": "images/icon-16.png",
        "32": "images/icon-32.png",
        "48": "images/icon-48.png",
        "128": "images/icon-128.png"
    },
    "background": {
        "service_worker": "background/service-worker.js",
        "type": "module"
    },
    "content_scripts": [
        {
            "matches": [
                "https://*.nhijudyshop.workers.dev/*",
                "https://nhijudyshop.workers.dev/*",
                "https://nhijudyshop.github.io/*",
                "https://nhijudy.store/*",
                "http://localhost:8080/*",
                "http://localhost:3000/*",
                "http://localhost:5173/*",
                "http://127.0.0.1:8080/*",
                "http://127.0.0.1:3000/*",
                "http://127.0.0.1:5173/*"
            ],
            "js": ["content/contentscript.js"],
            "run_at": "document_end"
        },
        {
            "matches": ["*://tomato.tpos.vn/*"],
            "js": ["content/tpos-interceptor.js"],
            "run_at": "document_start",
            "world": "MAIN"
        }
    ],
    "action": {
        "default_popup": "popup/popup.html",
        "default_icon": {
            "16": "images/icon-16.png",
            "32": "images/icon-32.png"
        }
    },
    "permissions": [
        "cookies",
        "storage",
        "declarativeNetRequestWithHostAccess",
        "notifications",
        "alarms",
        "webRequest",
        "tabs",
        "activeTab",
        "tabCapture"
    ],
    "host_permissions": [
        "*://business.facebook.com/*",
        "*://www.business.facebook.com/*",
        "*://upload-business.facebook.com/*",
        "*://www.facebook.com/*",
        "*://web.facebook.com/*",
        "*://graph.facebook.com/*",
        "*://p-upload.facebook.com/*",
        "https://*.nhijudyshop.workers.dev/*",
        "https://nhijudyshop.github.io/*",
        "https://nhijudy.store/*",
        "*://tomato.tpos.vn/*",
        "https://n2store-fallback.onrender.com/*",
        "http://localhost:8080/*",
        "http://localhost:3000/*",
        "http://localhost:5173/*",
        "http://127.0.0.1:8080/*",
        "http://127.0.0.1:3000/*",
        "http://127.0.0.1:5173/*",
        "<all_urls>"
    ],
    "commands": {
        "enable-stream-capture": {
            "suggested_key": {
                "default": "Ctrl+Shift+S",
                "mac": "Command+Shift+S"
            },
            "description": "Bật capture stream cho tab tpos-pancake (livestream snapshot)"
        }
    },
    "declarative_net_request": {
        "rule_resources": [
            {
                "id": "rules",
                "enabled": true,
                "path": "rules.json"
            }
        ]
    }
}
