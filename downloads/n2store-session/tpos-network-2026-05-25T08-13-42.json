        {
            "t": "resp",
            "s": 200,
            "url": "https://tomato.tpos.vn/BarcodeProductLabel/FormModal",
            "ct": "text/html; charset=utf-8",
            "at": 1779696842044,
            "body": "\r\n<div class=\"modal-header\">\r\n    <button aria-hidden=\"true\" class=\"close\" data-dismiss=\"modal\" type=\"button\" ng-click=\"vm.cancel()\">×</button>\r\n    <h4 class=\"modal-title\">{{'print.barcode'|translate}}<span class=\"o_subtitle text-muted small\"></span></h4>\r\n</div>\r\n\r\n<div class=\"modal-body o_act_window\" kendo-validator=\"vm.validator\">\r\n    <div class=\"o_view_manager_content\">\r\n        <div class=\"o_form_view o_form_editable\">\r\n            <div class=\"o_form_sheet_bg\">\r\n                <div class=\"o_form_sheet\">\r\n                    <div class=\"o_group\">\r\n                        <table class=\"o_group o_inner_group o_group_col_6\">\r\n                            <tbody>\r\n                                <tr>\r\n                                    <td colspan=\"1\" class=\"o_td_label\">\r\n                                        <label class=\"o_form_label\">\r\n                                            {{'label.price_list'|translate}}\r\n                                        </label>\r\n                                    </td>\r\n                                    <td colspan=\"1\" style=\"width: 100%;\">\r\n                                        <select kendo-combo-box\r\n                                                class=\"o_form_required\"\r\n                                                k-ng-model=\"vm.model.PriceList\"\r\n                                                name=\"vm.model.PriceList\"\r\n                                                k-data-text-field=\"'Name'\"\r\n                                                k-data-value-field=\"'Id'\"\r\n                                                k-filter=\"'contains'\"\r\n                                                k-auto-bind=\"false\"\r\n                                                k-min-length=\"1\"\r\n                                                k-change=\"vm.changePriceList\"\r\n                                                k-data-source=\"vm.priceListDataSource\"\r\n                                                style=\"width: 100%\" required validationMessage=\"{{'pricelist.select'|translate}}\"></select>\r\n                                        <span class=\"k-invalid-msg\" data-for=\"vm.model.PriceList\"></span>\r\n                                    </td>\r\n                                </tr>\r\n                                <tr>\r\n                                    <td colspan=\"1\" class=\"o_td_label\">\r\n                                        <label class=\"o_form_label\">\r\n                                            {{'print.paper'|translate}}\r\n                                        </label>\r\n                                    </td>\r\n                                    <td colspan=\"1\" style=\"width: 100%;\">\r\n                                        <select kendo-combo-box\r\n                                                class=\"o_form_required\"\r\n                                                k-ng-model=\"vm.model.Paper\"\r\n                                                name=\"vm.model.Paper\"\r\n                                                k-data-text-field=\"'Name'\"\r\n                                                k-data-value-field=\"'Id'\"\r\n                                                k-filter=\"'contains'\"\r\n                                                k-auto-bind=\"false\"\r\n                                                k-change=\"vm.changePaper\"\r\n                                                k-min-length=\"1\"\r\n                                                k-data-source=\"vm.paperDataSource\"\r\n                                                style=\"width: 100%\" required validationMessage=\"{{'print.select_paper'|translate}}\"></select>\r\n                                        <span class=\"k-invalid-msg\" data-for=\"vm.model.Paper\"></span>\r\n                                    </td>\r\n                                </tr>\r\n                            </tbody>\r\n                        </table>\r\n                        <table class=\"o_group o_inner_group o_group_col_6\">\r\n                            <tbody>\r\n                                <tr ng-if=\"vm.lines.length > 0\">\r\n                                    <td colspan=\"2\" class=\"o_td_label\">\r\n                                        <label class=\"o_form_label btn btn-sm btn-success\" ng-click=\"vm.quickApplyQuantity()\">\r\n                                            {{'label.quick_apply_quantity'|translate}}\r\n                                        </label>\r\n                                    </td>\r\n                                    <td colspan=\"1\" style=\"width: 100%;\">\r\n                                        <input focus-select-all-text kendo-numeric-text-box k-min=\"1\" k-decimals=\"0\" k-format=\"'n0'\" name=\"quickApplyQuantity\" k-ng-model=\"vm.applyQuantity\" style=\"width: 100%;\" />\r\n                                    </td>\r\n                                </tr>\r\n                            </tbody>\r\n                        </table>\r\n                        <table class=\"o_group o_inner_group o_group_col_12\">\r\n                            <tbody>\r\n                                <tr style=\"height:41.5px\">\r\n                                    <td class=\"o_td_label\">\r\n                                        <div class=\"o_checkbox o_form_field_boolean o_form_field\">\r\n                                            <label class=\"o_form_label m-r-10\" for=\"showPrice\">\r\n                                                {{'price.show'|translate}}\r\n                                            </label>\r\n                                            <input type=\"checkbox\" id=\"showPrice\" ng-model=\"vm.model.ShowPrice\" ng-click=\"vm.barcodeSetting()\">\r\n                                        </div>\r\n                                    </td>\r\n                                    <td class=\"o_td_label\">\r\n                                        <div class=\"o_checkbox o_form_field_boolean o_form_field\">\r\n                                            <label class=\"o_form_label m-r-10\" for=\"showBold\">\r\n                                                {{'label.bold'|translate}}\r\n                                            </label>\r\n                                            <input type=\"checkbox\" id=\"showBold\" ng-model=\"vm.model.ShowBold\" ng-click=\"vm.barcodeSetting()\">\r\n                                        </div>\r\n                                    </td>\r\n                                    <td class=\"o_td_label\">\r\n                                        <div class=\"o_checkbox o_form_field_boolean o_form_field\">\r\n                                            <label class=\"o_form_label m-r-10\" for=\"showCurrency\">\r\n                                                {{'currency.show_uint'|translate}}\r\n                                            </label>\r\n                                            <input type=\"checkbox\" id=\"showCurrency\" ng-model=\"vm.model.ShowCurrency\" ng-click=\"vm.barcodeSetting()\">\r\n                                        </div>\r\n                                    </td>\r\n                                    <td class=\"o_td_label\">\r\n                                        <div class=\"o_checkbox o_form_field_boolean o_form_field\">\r\n                                            <label class=\"o_form_label m-r-10\" for=\"showProductName\">\r\n                                                {{'label.display'|translate}} {{'product.name'|translate}}\r\n                                            </label>\r\n                                            <input type=\"checkbox\" id=\"showProductName\" ng-model=\"vm.model.ShowProductName\" ng-click=\"vm.barcodeSetting()\">\r\n                                        </div>\r\n                                    </td>\r\n                                </tr>\r\n                                <tr style=\"height:41.5px\">\r\n                                    <td colspan=\"4\" class=\"o_td_label\">\r\n                                        <div class=\"o_checkbox o_form_field_boolean o_form_field\">\r\n                                            <label class=\"o_form_label m-r-10\" for=\"IsHideBarcode\">\r\n                                                {{'label.hide_barcodes'|translate}} ({{'label.recommended_for_default_print_type' | translate}})\r\n                                            </label>\r\n                                            <input type=\"checkbox\" id=\"IsHideBarcode\" ng-model=\"vm.model.IsHideBarcode\" ng-click=\"vm.barcodeSetting()\">\r\n                                        </div>\r\n                                    </td>\r\n                                </tr></tbody>\r\n                        </table>\r\n                    </div>\r\n                    <div class=\"text-warning-dk\" ng-if=\"vm.lineErrors.length > 0\">\r\n                        <span class=\"fa fa-warning\"></span>\r\n                        {{'warning.product_without_barcode_will_not_be_print'|translate}}\r\n                        <span ng-if=\"vm.errorMsg\">\r\n                            : {{vm.errorMsg}}\r\n                        </span>\r\n                    </div>\r\n                </div>\r\n            </div>\r\n        </div>\r\n    </div>\r\n</div>\r\n<div class=\"o_view_manager_content\">\r\n    <div class=\"o_form_view o_form_editable\">\r\n        <div class=\"o_form_sheet_bg\">\r\n            <div class=\"o_form_sheet\">\r\n                <uib-tabset active=\"vm.orderTabIndex\">\r\n                    <uib-tab heading=\"{{'label.products_have_barcode' | translate}}\">\r\n                        <div class=\"o_field_one2many o_field_widget o_field_x2many o_field_x2many_list\" kendo-validator=\"vm.validator2\">\r\n\r\n                            <div class=\"table-responsive\">\r\n                                <table class=\"o_list_view table table-condensed table-striped o_list_view_ungrouped\">\r\n                                    <thead>\r\n                                        <tr>\r\n                                            <th>{{'label.product'|translate}}</th>\r\n                                            <th>{{'label.quantity'|translate}}</th>\r\n                                            <th></th>\r\n                                        </tr>\r\n                                    </thead>\r\n                                    <tbody>\r\n                                        <tr ng-repeat=\"line in vm.lines\">\r\n                                            <td>{{line.Product.NameGet}}</td>\r\n                                            <td>\r\n                                                <input focus-select-all-text kendo-numeric-text-box k-min=\"0\" k-decimals=\"0\" k-format=\"'n0'\" name=\"vm.lines[{{$index}}].Quantity\" k-ng-model=\"line.Quantity\" style=\"width: 100%;\" required validationMessage=\"{{'label.import_qty'|translate}}\" />\r\n                                                <span class=\"k-invalid-msg\" data-for=\"vm.lines[{{$index}}].Quantity\"></span>\r\n                                            </td>\r\n                                            <td class=\"o_list_record_delete\">\r\n                                                <button type=\"button\" class=\"btn btn-sm btn-default\" ng-click=\"vm.remove_line($index)\">\r\n                                                    <span class=\"fa fa-trash-o\"></span>\r\n                                                </button>\r\n                                            </td>\r\n                                        </tr>\r\n                                        <tr>\r\n                                            <td colspan=\"3\" class=\"o_form_field_x2many_list_row_add\"><a ng-click=\"vm.add_line()\">{{'product.add'|translate}}</a></td>\r\n                                        </tr>\r\n                                    </tbody>\r\n                                    <tfoot>\r\n                                        <tr>\r\n                                            <td></td>\r\n                                            <td></td>\r\n                                            <td></td>\r\n                                        </tr>\r\n                                    </tfoot>\r\n                                </table>\r\n                            </div>\r\n                        </div>\r\n                    </uib-tab>\r\n                    <uib-tab heading=\"{{'label.products_have_not_barcode' | translate}}\">\r\n                        <div class=\"o_field_one2many o_field_widget o_field_x2many o_field_x2many_list\" kendo-validator=\"vm.validator3\">\r\n                            <form method=\"post\" action=\"#\">\r\n                                <div class=\"table-responsive\">\r\n                                    <table class=\"o_list_view table table-condensed table-striped o_list_view_ungrouped\">\r\n                                        <thead>\r\n                                            <tr>\r\n                                                <th>{{'label.product'|translate}}</th>\r\n                                                <th>{{'label.barcode'|translate}}</th>\r\n                                                <th></th>\r\n                                            </tr>\r\n                                        </thead>\r\n                                        <tbody>\r\n                                            <tr ng-repeat=\"line in vm.lineErrors\">\r\n                                                <td>{{line.ProductName}}</td>\r\n                                                <td>\r\n                                                    <input class=\"form-control\" id=\"{{vm.lineErrors[$index].Id}}\" name=\"{{vm.lineErrors[$index].Id}}\" ng-model=\"line.Barcode\" style=\"width: 100%;\" required validationMessage=\"{{'error.please_enter_barcode'|translate}}\" />\r\n                                                    <span class=\"k-invalid-msg\" data-for=\"{{vm.lineErrors[$index].Id}}\"></span>\r\n                                                </td>\r\n                                                <td class=\"o_list_record_delete\">\r\n                                                    \r\n                                                </td>\r\n                                            </tr>\r\n                                            <tr>\r\n                                                <td colspan=\"3\" class=\"o_form_field_x2many_list_row_add\"><a ng-click=\"vm.updateBarcodes()\">{{'label.update_barcode'|translate}}</a></td>\r\n                                            </tr>\r\n                                        </tbody>\r\n                                        <tfoot>\r\n                                            <tr>\r\n                                                <td></td>\r\n                                                <td></td>\r\n                                                <td></td>\r\n                                            </tr>\r\n                                        </tfoot>\r\n                                    </table>\r\n                                </div>\r\n                            </form>\r\n                        </div>\r\n                    </uib-tab>\r\n                </uib-tabset>\r\n            </div>\r\n        </div>\r\n    </div>\r\n</div>\r\n<div class=\"modal-footer\">\r\n    <div>\r\n        <footer>\r\n            <button type=\"button\" class=\"btn btn-sm btn-primary\" check-permission='App.Catalog.ProductTemplate.PrintBarcode' ng-click=\"vm.savePdf()\">\r\n                <span>{{'print.pdf'|translate}}</span>\r\n            </button>\r\n            <button type=\"button\" class=\"btn btn-sm btn-default\" ng-click=\"vm.cancel()\">\r\n                <span>{{'label.close'|translate}}</span>\r\n            </button>\r\n        </footer>\r\n    </div>\r\n</div>\r\n\r\n\r\n"
        },
