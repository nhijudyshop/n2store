                "url": "/BarcodeProductLabel/FormModal",
                "status": 200,
                "ct": "text/html; charset=utf-8",
                "bodyLen": 15392,
                "body": "\r\n<div class=\"modal-header\">\r\n    <button aria-hidden=\"true\" class=\"close\" data-dismiss=\"modal\" type=\"button\" ng-click=\"vm.cancel()\">×</button>\r\n    <h4 class=\"modal-title\">{{'print.barcode'|translate}}<span class=\"o_subtitle text-muted small\"></span></h4>\r\n</div>\r\n\r\n<div class=\"modal-body o_act_window\" kendo-validator=\"vm.validator\">\r\n    <div class=\"o_view_manager_content\">\r\n        <div class=\"o_form_view o_form_editable\">\r\n            <div class=\"o_form_sheet_bg\">\r\n                <div class=\"o_form_sheet\">\r\n                    <div class=\"o_group\">\r\n                        <table class=\"o_group o_inner_group o_group_col_6\">\r\n                            <tbody>\r\n                                <tr>\r\n                                    <td colspan=\"1\" class=\"o_td_label\">\r\n                                        <label class=\"o_form_label\">\r\n                                            {{'label.price_list'|translate}}\r\n                                        </label>\r\n                                    </td>\r\n                                    <td colspan=\"1\" style=\"width: 100%;\">\r\n                                        <select kendo-combo-box\r\n                                                class=\"o_form_required\"\r\n                                                k-ng-model=\"vm.model.PriceList\"\r\n                                                name=\"vm.model.PriceList\"\r\n                                                k-data-text-field=\"'Name'\"\r\n                                                k-data-value-field=\"'Id'\"\r\n                                                k-filter=\"'contains'\"\r\n                                                k-auto-bind=\"false\"\r\n                                                k-min-length=\"1\"\r\n                                                k-change=\"vm.changePriceList\"\r\n                                                k-data-source=\"vm.priceListDataSource\"\r\n                                                style=\"width: 100%\" required validationMessage=\"{{'pricelist.select'|translate}}\"></select>\r\n                                        <span class=\"k-invalid-msg\" data-for=\"vm.model.PriceList\"></span>\r\n                                    </td>\r\n                                </tr>\r\n                                <tr>\r\n                                    <td colspan=\"1\" class=\"o_td_label\">\r\n                                        <label class=\"o_form_label\">\r\n                                            {{'print.paper'|translate}}\r\n                                        </label>\r\n                                    </td>\r\n                                    <td colspan=\"1\" style=\"width: 100%;\">\r\n                                        <select kendo-combo-box\r\n                                                class=\"o_form_required\"\r\n                                                k-ng-model=\"vm.model.Paper\"\r\n                                                name=\"vm.model.Paper\"\r\n                                                k-data-text-field=\"'Name'\"\r\n                                                k-data-value-field=\"'Id'\"\r\n                                                k-filter=\"'contains'\"\r\n                                                k-auto-bind=\"false\"\r\n                                                k-change=\"vm.changePaper\"\r\n                                                k-min-length=\"1\"\r\n                                                k-data-source=\"vm.paperDataSource\"\r\n                                                style=\"width: 100%\" required validationMessage=\"{{'print.select_paper'|translate}}\"></select>\r\n                                        <span class=\"k-invalid-msg\" data-for=\"vm.model.Paper\"></span>\r\n                                    </td>\r\n                                </tr>\r\n                            </tbody>\r\n                        </table>\r\n                        <table class=\"o_group o_inner_group o_group_col_6\">\r\n                            <tbody>\r\n                                <tr ng-if=\"vm.lines.length > 0\">\r\n                                    <td colspan=\"2\" class=\"o_td_label\">\r\n                                        <label class=\"o_form_label btn btn-sm btn-success\" ng-click=\"vm.quickApplyQuantity()\">\r\n                                            {{'label.quick_apply_quantity'|translate}}\r\n                                        </label>\r\n                                    </td>\r\n                                    <td colspan=\"1\" style=\"width: 100%;\">\r\n                                        <input focus-select-all-text kendo-numeric-text-box k-min=\"1\" k-decimals=\"0\" k-format=\"'n0'\" name=\"quickApplyQuantity\" k-ng-model=\"vm.applyQuantity\" style=\"width: 100%;\" />\r\n                                    </td>\r\n                                </tr>\r\n                            </tbody>\r\n                        </table>\r\n                        <table class=\"o_group o_inner_group o_group_col_12\">\r\n                            <tbody>\r\n                                <tr style=\"height:41.5px\">\r\n                                    <td class=\"o_td_label\">\r\n                                        <div class=\"o_checkbox o_form_field_boolean o_form_field\">\r\n                                            <label class=\"o_form_label m-r-10\" for=\"showPrice\">\r\n                                                {{'price.show'|translate}}\r\n                                            </label>\r\n                                            <input type=\"checkbox\" id=\"showPrice\" ng-model=\"vm.model.ShowPrice\" ng-click=\"vm.barcodeSetting()\">\r\n                                        </div>\r\n                                    </td>\r\n                                    <td class=\"o_td_label\">\r\n                                        <div class=\"o_checkbox o_form_field_boolean o_form_field\">\r\n                                            <label class=\"o_form_label m-r-10\" for=\"showBold\">\r\n                                                {{'label.bold'|translate}}\r\n                                            </label>\r\n                                            <input type=\"checkbox\" id=\"showBold\" ng-model=\"vm.model.ShowBold\" ng-click=\"vm.barcodeSetting()\">\r\n                                        </div>\r\n                                    </td>\r\n                                    <td class=\"o_td_label\">\r\n                                        <div class=\"o_checkbox o_form_field_boolean o_form_field\">\r\n                                            <label class=\"o_form_label m-r-10\" for=\"showCurrency\">\r\n                                                {{'currency.show_uint'|translate}}\r\n                                            </label>\r\n                                            <input type=\"checkbox\" id=\"showCurrency\" ng-model=\"vm.model.ShowCurrency\" ng-click=\"vm.barcodeSetting()\">\r\n                                        </div>\r\n                                    </td>\r\n                                    <td class=\"o_td_label\">\r\n                                        <div class=\"o_checkbox o_form_field_boolean o_form_field\">\r\n                                            <label class=\"o_form_label m-r-10\" for=\"showProductName\">\r\n                                                {{'label.display'|translate}} {{'product.name'|translate}}\r\n                                            </label>\r\n                                            <input type=\"checkbox\" id=\"showProductName\" ng-model=\"vm.model.ShowProductName\" ng-click=\"vm.barcodeSetting()\">\r\n                                  