rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper function to check if user is admin
    function isAdmin() {
      return isAuthenticated() &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Customers collection - accessible by authenticated users, writable by admin
    match /customers/{customerId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Users collection - only admins can read/write
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Purchase Orders collection
    match /purchase_orders/{orderId} {
      // Helper: Check if user owns the order
      function isOwner() {
        return resource.data.createdBy.uid == request.auth.uid;
      }

      // Helper: Check if user is creating with their own ID
      function isCreatingAsOwner() {
        return request.resource.data.createdBy.uid == request.auth.uid;
      }

      // Anyone authenticated can read
      allow read: if isAuthenticated();

      // Can create if authenticated AND setting themselves as owner
      allow create: if isAuthenticated() && isCreatingAsOwner();

      // Can update if authenticated, is owner or admin, and order is not COMPLETED
      allow update: if isAuthenticated()
        && (isOwner() || isAdmin())
        && resource.data.status != 'COMPLETED';

      // Can delete if authenticated, is owner or admin, and order is DRAFT or CANCELLED
      allow delete: if isAuthenticated()
        && (isOwner() || isAdmin())
        && resource.data.status in ['DRAFT', 'CANCELLED'];
    }

    // Sổ Quỹ (Cash Book) - vouchers collection
    match /soquy_vouchers/{voucherId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAdmin();
    }

    // Sổ Quỹ - auto-increment counters
    match /soquy_counters/{counterId} {
      allow read, write: if isAuthenticated();
    }

    // Sổ Quỹ - dynamic metadata (categories, creators)
    match /soquy_meta/{metaId} {
      allow read, write: if isAuthenticated();
    }

    // KPI BASE - chỉ tạo mới, update chỉ cho merge fields
    match /kpi_base/{docId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated()
        && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['superseded_by_merge', 'mergedAt', 'merged_into']);
      allow delete: if false;
    }

    // KPI Audit Log - append-only
    match /kpi_audit_log/{logId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if false;
      allow delete: if false;
    }

    // Edit History (Audit Log) - append-only, readable by authenticated users
    match /edit_history/{logId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if false;
      allow delete: if isAdmin();
    }

    // KPI Statistics - read/write, no delete
    match /kpi_statistics/{userId}/{document=**} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated();
      allow delete: if false;
    }

    // Default: deny all other access
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
