rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // =============================================
    // App Config & Settings
    // =============================================

    match /app_config/{docId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    match /settings/{docId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    // =============================================
    // Users & Permissions
    // =============================================

    match /users/{userId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    match /permission_templates/{templateId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    match /user_preferences/{docId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    // Customers collection
    match /customers/{customerId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    // =============================================
    // Tokens & Integration
    // =============================================

    match /tokens/{tokenId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    match /pancake_tokens/{tokenId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    match /pancake_images/{imageId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    // =============================================
    // Products
    // =============================================

    match /products/{productId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    match /product_stats/{docId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    match /balance_history/{docId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    // =============================================
    // Purchase Orders & Goods Receiving
    // =============================================

    match /purchase_orders/{orderId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    match /purchase_order_items/{itemId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    match /goods_receiving/{docId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    match /goods_receiving_items/{itemId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    match /supplier_debt_notes/{docId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    // =============================================
    // Inventory Tracking
    // =============================================

    match /inventory_tracking/{docId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    match /inventory_prepayments/{docId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    match /inventory_other_expenses/{docId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    // =============================================
    // Nhận Hàng (Goods Receipt)
    // =============================================

    match /nhanhang/{docId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    // =============================================
    // Hàng Hoán, Bán Hàng, Trả Hàng, Đối Soát
    // =============================================

    match /hanghoan/{docId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    match /ban_hang/{docId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    match /tra_hang/{docId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    match /doi_soat/{docId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    // =============================================
    // Other Business Modules
    // =============================================

    match /ck/{docId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    match /hangrotxa/{docId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    match /ib/{docId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    match /dathang/{docId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    match /ncc-names/{docId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    match /campaigns/{docId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    // =============================================
    // Sổ Quỹ (Cash Book)
    // =============================================

    match /soquy_vouchers/{voucherId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    match /soquy_counters/{counterId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    match /soquy_meta/{metaId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    match /soquy_edit_history/{docId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update: if false;
      allow delete: if isAuthenticated();
    }

    // =============================================
    // Orders & Reports
    // =============================================

    match /order-logs/{docId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    match /return-logs/{docId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    match /report_order_details/{docId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    // Subcollection for report chunks
    match /report_order_details/{docId}/order_chunks/{chunkId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    match /invoice_status_v2/{docId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    match /invoice_status_delete_v2/{docId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    match /order_creation_history/{docId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update, delete: if false;
    }

    match /merge_orders_history/{docId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update, delete: if false;
    }

    // =============================================
    // KPI
    // =============================================

    match /kpi_base/{docId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    match /kpi_audit_log/{logId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update, delete: if false;
    }

    match /kpi_statistics/{userId}/{document=**} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    // =============================================
    // Edit History (Audit Log)
    // =============================================

    match /edit_history/{logId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update: if false;
      allow delete: if isAuthenticated();
    }

    // =============================================
    // Attendance
    // =============================================

    match /attendance_records/{docId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    match /attendance_device_users/{docId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    match /attendance_commands/{docId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    match /attendance_sync_status/{docId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    // =============================================
    // Communication & Chat
    // =============================================

    match /message_templates/{docId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    match /message_campaigns/{docId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    match /quickReplies/{docId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    // =============================================
    // Livestream
    // =============================================

    match /livestream_reports/{docId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    // =============================================
    // Default: deny all other access
    // =============================================
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
