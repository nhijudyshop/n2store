rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper function to check if user is admin
    function isAdmin() {
      return isAuthenticated() &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // =============================================
    // App Config & Settings
    // =============================================

    // App configuration (version check, etc.)
    match /app_config/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Application settings
    match /settings/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // =============================================
    // Users & Permissions
    // =============================================

    // Users collection - read allowed without auth for login flow
    // (app reads user doc to verify password BEFORE signInAnonymously)
    match /users/{userId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Permission templates
    match /permission_templates/{templateId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Customers collection
    match /customers/{customerId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // =============================================
    // Tokens & Integration
    // =============================================

    // TPOS tokens
    match /tokens/{tokenId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    // Pancake integration tokens
    match /pancake_tokens/{tokenId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    // Pancake cached images
    match /pancake_images/{imageId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    // =============================================
    // Products
    // =============================================

    match /products/{productId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    match /product_stats/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    match /balance_history/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    // =============================================
    // Purchase Orders & Goods Receiving
    // =============================================

    match /purchase_orders/{orderId} {
      function isOwner() {
        return resource.data.created_by == request.auth.uid;
      }
      function isCreatingAsOwner() {
        return request.resource.data.created_by == request.auth.uid;
      }

      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isCreatingAsOwner();
      allow update: if isAuthenticated()
        && (isOwner() || isAdmin())
        && resource.data.status != 'COMPLETED';
      allow delete: if isAuthenticated()
        && (isOwner() || isAdmin())
        && resource.data.status in ['DRAFT', 'CANCELLED'];
    }

    match /purchase_order_items/{itemId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated();
      allow delete: if isAuthenticated();
    }

    match /goods_receiving/{docId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated();
      allow delete: if isAdmin();
    }

    match /goods_receiving_items/{itemId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated();
      allow delete: if isAuthenticated();
    }

    match /supplier_debt_notes/{docId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated();
      allow delete: if isAdmin();
    }

    // =============================================
    // Inventory Tracking
    // =============================================

    match /inventory_tracking/{docId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated();
      allow delete: if isAdmin();
    }

    match /inventory_prepayments/{docId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated();
      allow delete: if isAdmin();
    }

    match /inventory_other_expenses/{docId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated();
      allow delete: if isAdmin();
    }

    // =============================================
    // Nhận Hàng (Goods Receipt)
    // =============================================

    match /nhanhang/{docId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated();
      allow delete: if isAdmin();
    }

    // =============================================
    // Hàng Hoán, Bán Hàng, Trả Hàng, Đối Soát
    // =============================================

    match /hanghoan/{docId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated();
      allow delete: if isAdmin();
    }

    match /ban_hang/{docId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated();
      allow delete: if isAdmin();
    }

    match /tra_hang/{docId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated();
      allow delete: if isAdmin();
    }

    match /doi_soat/{docId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated();
      allow delete: if isAdmin();
    }

    // =============================================
    // Other Business Modules
    // =============================================

    // CK module
    match /ck/{docId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated();
      allow delete: if isAdmin();
    }

    // Hàng Rót Xả
    match /hangrotxa/{docId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated();
      allow delete: if isAdmin();
    }

    // IB (Inventory Book)
    match /ib/{docId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated();
      allow delete: if isAdmin();
    }

    // Đặt Hàng
    match /dathang/{docId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated();
      allow delete: if isAdmin();
    }

    // Bảng Kiểm Hàng (NCC names)
    match /ncc-names/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    // =============================================
    // Sổ Quỹ (Cash Book)
    // =============================================

    match /soquy_vouchers/{voucherId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAdmin();
    }

    match /soquy_counters/{counterId} {
      allow read, write: if isAuthenticated();
    }

    match /soquy_meta/{metaId} {
      allow read, write: if isAuthenticated();
    }

    match /soquy_edit_history/{docId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if false;
      allow delete: if isAdmin();
    }

    // =============================================
    // Orders & Reports
    // =============================================

    match /order-logs/{docId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated();
      allow delete: if isAdmin();
    }

    match /return-logs/{docId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated();
      allow delete: if isAdmin();
    }

    match /report_order_details/{docId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated();
      allow delete: if false;
    }

    // Invoice status tracking
    match /invoice_status_v2/{docId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated();
      allow delete: if isAuthenticated();
    }

    match /invoice_status_delete_v2/{docId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated();
      allow delete: if isAuthenticated();
    }

    match /order_creation_history/{docId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if false;
      allow delete: if false;
    }

    match /merge_orders_history/{docId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if false;
      allow delete: if false;
    }

    // =============================================
    // KPI
    // =============================================

    match /kpi_base/{docId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated()
        && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['superseded_by_merge', 'mergedAt', 'merged_into']);
      allow delete: if false;
    }

    match /kpi_audit_log/{logId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if false;
      allow delete: if false;
    }

    match /kpi_statistics/{userId}/{document=**} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated();
      allow delete: if false;
    }

    // =============================================
    // Edit History (Audit Log)
    // =============================================

    match /edit_history/{logId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if false;
      allow delete: if isAdmin();
    }

    // =============================================
    // Attendance
    // =============================================

    match /attendance_records/{docId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated();
      allow delete: if isAdmin();
    }

    match /attendance_device_users/{docId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated();
      allow delete: if isAdmin();
    }

    match /attendance_commands/{docId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated();
      allow delete: if isAuthenticated();
    }

    match /attendance_sync_status/{docId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated();
      allow delete: if false;
    }

    // =============================================
    // Communication & Chat
    // =============================================

    match /message_templates/{docId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated();
      allow delete: if isAdmin();
    }

    match /message_campaigns/{docId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated();
      allow delete: if isAdmin();
    }

    match /quickReplies/{docId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated();
      allow delete: if isAuthenticated();
    }

    // =============================================
    // Livestream
    // =============================================

    match /livestream_reports/{docId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated();
      allow delete: if isAdmin();
    }

    // =============================================
    // Default: deny all other access
    // =============================================
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
